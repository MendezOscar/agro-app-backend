# Copia a .env y ajusta. Usado por backend/clientes en desarrollo.

# --- Base de datos (coincide con docker-compose) ---
ConnectionStrings__Default=Host=localhost;Port=5433;Database=agroapp;Username=agroapp;Password=agroapp_dev

# --- MinIO (S3-compatible) ---
Storage__Endpoint=http://localhost:9000
Storage__AccessKey=agroapp
Storage__SecretKey=agroapp_dev
Storage__Bucket=agroapp-images

# --- JWT ---
Jwt__Issuer=agroapp
Jwt__Audience=agroapp
Jwt__Key=CAMBIA_ESTA_CLAVE_POR_UNA_LARGA_Y_ALEATORIA_MIN_32_CHARS

# --- Claude vision (solo backend) ---
Anthropic__ApiKey=sk-ant-xxxxx
Anthropic__Model=claude-opus-4-8

# --- Mapbox (clientes: Flutter y Vue) ---
MAPBOX_TOKEN=pk.xxxxx
